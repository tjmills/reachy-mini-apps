# Required Hugging Face access token.
HF_TOKEN=hf_your_token_here

# Remote inference.
DOG_TRACKER_MODEL=hustvl/yolos-tiny
DOG_TRACKER_LABEL=dog
DOG_TRACKER_CONF=0.5
DOG_TRACKER_DETECTION_HZ=2.0
# DOG_TRACKER_ENDPOINT_URL=https://your-endpoint.region.endpoints.huggingface.cloud

# Robot control.
DOG_TRACKER_CONTROL_HZ=50.0
DOG_TRACKER_LOST_TIMEOUT=2.0
DOG_TRACKER_SCAN_AMPLITUDE_DEG=25.0
DOG_TRACKER_SCAN_PERIOD=6.0

# Reaction behavior.
DOG_TRACKER_REACTION_EMOTION=surprised1
# DOG_TRACKER_REACTION_AUDIO=gotobed.wav
DOG_TRACKER_REACTION_COOLDOWN=15.0
